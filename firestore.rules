rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can only ever read or write their own document tree.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
